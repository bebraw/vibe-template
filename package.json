{
  "name": "vibe-template",
  "private": true,
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": "22.17.1",
    "npm": "10.9.2"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.17.1",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "10.9.2",
      "onFail": "error"
    }
  },
  "scripts": {
    "ci:local": "node ./scripts/run-local-ci.mjs --workflow .github/workflows/ci.yml",
    "ci:local:quiet": "node ./scripts/run-local-ci.mjs --quiet --workflow .github/workflows/ci.yml",
    "ci:local:all": "node ./scripts/run-local-ci.mjs --all",
    "e2e": "playwright test --pass-with-no-tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lighthouse": "node ./scripts/run-lighthouse.mjs",
    "quality:gate": "npm run format:check && npm run typecheck && npm run security:audit && npm test && npm run e2e",
    "screenshots:readme": "node ./scripts/capture-readme-screenshots.mjs",
    "security:audit": "npm audit --audit-level=high --omit=dev",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@redwoodjs/agent-ci": "0.6.0",
    "chrome-launcher": "1.2.1",
    "lighthouse": "13.0.3",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "vitest": "4.1.1",
    "wrangler": "4.77.0"
  }
}
