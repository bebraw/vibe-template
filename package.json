{
  "name": "vibe-template",
  "private": true,
  "packageManager": "npm@11.11.1",
  "engines": {
    "node": "22.x",
    "npm": "11.11.1"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "22.x",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.11.1",
      "onFail": "error"
    }
  },
  "scripts": {
    "ci:local": "agent-ci run --workflow .github/workflows/ci.yml",
    "ci:local:quiet": "agent-ci run --quiet --workflow .github/workflows/ci.yml",
    "ci:local:all": "agent-ci run --all",
    "e2e": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lighthouse": "node ./scripts/run-lighthouse.mjs",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@redwoodjs/agent-ci": "0.6.0",
    "chrome-launcher": "1.2.1",
    "lighthouse": "13.0.3",
    "prettier": "3.8.1",
    "vitest": "4.1.1",
    "wrangler": "4.77.0"
  }
}
